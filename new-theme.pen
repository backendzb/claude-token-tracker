                          "content": "Please analyse this codebase and create a CLAUDE.md file, which will be given to future instances of Claude Code to operate in this repository.",
                          "fontFamily": "$--font-main",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "text",
                          "id": "vYEwh",
                          "fill": "$--text-primary",
