                          "type": "text",
                          "id": "szuWw",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "1. Commands that will be commonly used, such as how to build, lint, and run tests. Include the necessary commands to develop in this codebase, such as how to run a single test.",
                          "fontFamily": "$--font-main",
                          "fontSize": 11,
