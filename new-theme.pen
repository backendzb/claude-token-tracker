                        },
                        {
                          "type": "text",
                          "id": "CNTnW",
                          "fill": "$--text-secondary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "- If there's already a CLAUDE.md, suggest improvements to it.\n- When you write the initial CLAUDE.md, do not repeat yourself and do not include obvious instructions like \"Provide helpful and clear messages to users\".\n- Write out tests to all or new utilities if there is no test file yet.\n- Avoid listing every component or file structure that can be easily discovered.",
                          "fontFamily": "$--font-main",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        },
